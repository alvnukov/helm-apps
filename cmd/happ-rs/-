global:
  env: dev
apps-configmaps:
  demo-config:
    enabled: true
    name: demo-config
    data: 'APP_MODE: prod'
apps-services:
  demo-svc:
    enabled: true
    name: demo-svc
    ports: |-
      - name: http
        port: 80
        targetPort: 8080
    selector: 'app: demo'
    type: ClusterIP
